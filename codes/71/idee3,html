            transport: 95,
            abonnementen: 75,
            overig: 510,
          },
          spaargeld: 18900,
          laatste_login: "2026-05-27",
          avatar_kleur: "#FF8FAB",
        },
        {
          id: 3,
          naam: "Zeke Jeager",
          leeftijd: 34,
          beroep: "Data Analyst",
          stad: "Utrecht",
          maandelijks_inkomen: 3650,
          valuta: "EUR",
          inkomen_bronnen: {
            salaris: 3100,
            freelance: 300,
            investeringen: 250,
          },
          maandelijkse_kosten: {
            huur: 980,
            boodschappen: 340,
            transport: 180,
            abonnementen: 45,
            overig: 395,
          },
          spaargeld: 22100,
          laatste_login: "2026-05-26",
          avatar_kleur: "#5ECFA0",
        },
        {
          id: 4,
          naam: "Alex Braun",
          leeftijd: 37,
          beroep: "Marketing Manager",
          stad: "Rotterdam",
          maandelijks_inkomen: 5100,
          valuta: "EUR",
          inkomen_bronnen: {
            salaris: 4500,
            freelance: 350,
            investeringen: 250,
          },
          maandelijkse_kosten: {
            huur: 1600,
            boodschappen: 380,
            transport: 210,
            abonnementen: 90,
            overig: 620,
          },
          spaargeld: 34750,
          laatste_login: "2026-05-28",
          avatar_kleur: "#FFB347",
        },
      ];

      const eur = (v) => "€" + v.toLocaleString("nl-NL");
      const initials = (n) =>
        n
          .split(" ")
          .map((w) => w[0])
          .join("")
          .slice(0, 2)
          .toUpperCase();
      const totalKosten = (p) =>
        Object.values(p.maandelijkse_kosten).reduce((a, b) => a + b, 0);
      const balance = (p) => p.maandelijks_inkomen - totalKosten(p);

      /* CHARTS */
      Chart.defaults.color = "#64748b";
      Chart.defaults.font.family = "'DM Mono', monospace";
      Chart.defaults.font.size = 11;

      function buildHomeCharts() {
        const names = data.map((p) => p.naam.split(" ")[0]);
        new Chart(document.getElementById("chartIncome"), {
          type: "bar",
          data: {
            labels: names,
            datasets: [
              {
                label: "Salaris",
                data: data.map((p) => p.inkomen_bronnen.salaris),
                backgroundColor: "rgba(108,158,255,0.7)",
                borderRadius: 4,
              },
              {
                label: "Freelance",
                data: data.map((p) => p.inkomen_bronnen.freelance),
                backgroundColor: "rgba(167,139,250,0.7)",
                borderRadius: 4,
              },
              {
                label: "Investeringen",
                data: data.map((p) => p.inkomen_bronnen.investeringen),
                backgroundColor: "rgba(94,207,160,0.7)",
                borderRadius: 4,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: {
                stacked: true,
                grid: { color: "rgba(148,163,184,0.05)" },
                ticks: { color: "#64748b" },
              },
              y: {
                stacked: true,
                grid: { color: "rgba(148,163,184,0.05)" },
                ticks: {
                  color: "#64748b",
                  callback: (v) => "€" + v.toLocaleString("nl-NL"),
                },
              },
            },
          },
        });

        const cats = [
          "Huur",
          "Boodschappen",
          "Transport",
          "Abonnementen",
          "Overig",
        ];
        const totals = [
          "huur",
          "boodschappen",
          "transport",
          "abonnementen",
          "overig",
        ].map(
          (k) =>
            data.reduce((a, p) => a + p.maandelijkse_kosten[k], 0) /
            data.length,
        );
        new Chart(document.getElementById("chartKosten"), {
          type: "doughnut",
          data: {
            labels: cats,
            datasets: [
              {
                data: totals,
                backgroundColor: [
                  "rgba(108,158,255,0.8)",
                  "rgba(94,207,160,0.8)",
                  "rgba(255,179,71,0.8)",
                  "rgba(167,139,250,0.8)",
                  "rgba(255,143,171,0.8)",
                ],
                borderWidth: 0,
                hoverOffset: 6,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            cutout: "68%",
          },
        });
      }

      /* PEOPLE GRID */
      function buildPeopleGrid() {
        const g = document.getElementById("people-grid");
        g.innerHTML = data
          .map(
            (p) => `
    <div class="person-card" style="--accent:${p.avatar_kleur}" onclick="showPage('profile',${p.id})">
      <div class="person-arrow">↗</div>
      <div class="person-avatar" style="background:${p.avatar_kleur}">${initials(p.naam)}</div>
      <div class="person-name">${p.naam}</div>
      <div class="person-role">${p.beroep} · ${p.stad}</div>
      <div class="person-income">${eur(p.maandelijks_inkomen)}</div>
      <div class="person-income-lbl">/ maand bruto</div>
      <div class="person-tags">
        <span class="tag">${p.leeftijd} jaar</span>
        <span class="tag">${eur(p.spaargeld)} gespaard</span>
      </div>
    </div>
  `,
          )
          .join("");
      }

      /* LEADERBOARD */
      function buildLeaderboard() {
        const sorted = [...data].sort((a, b) => b.spaargeld - a.spaargeld);
        const max = sorted[0].spaargeld;
        document.getElementById("leaderboard").innerHTML = sorted
          .map(
            (p, i) => `
    <div class="lb-row" onclick="showPage('profile',${p.id})">
      <span class="lb-rank">${i + 1}</span>
      <div class="lb-avatar" style="background:${p.avatar_kleur}">${initials(p.naam)}</div>
      <div class="lb-info">
        <div class="lb-name">${p.naam}</div>
        <div class="lb-city">${p.stad} · ${p.beroep}</div>
      </div>
      <div class="lb-bar-wrap"><div class="lb-bar" style="width:${Math.round((p.spaargeld / max) * 100)}%;background:${p.avatar_kleur}"></div></div>
      <div class="lb-amount">${eur(p.spaargeld)}</div>
    </div>
  `,
          )
          .join("");
      }

      /* PROFILE BUILDER */
      const kostKleuren = {
        huur: "#6C9EFF",
        boodschappen: "#5ECFA0",
        transport: "#FFB347",
        abonnementen: "#a78bfa",
        overig: "#FF8FAB",
      };
      const kostLabels = {
        huur: "Huur",
        boodschappen: "Boodschappen",
        transport: "Transport",
        abonnementen: "Abonnementen",
        overig: "Overig",
      };

      function buildProfile(p) {
        const tk = totalKosten(p);
        const bal = balance(p);
        const savMonths = Math.round(p.spaargeld / bal);

        const incBreak = Object.entries(p.inkomen_bronnen)
          .map(
            ([k, v]) => `
    <div class="breakdown-item">
      <div class="breakdown-dot" style="background:${k === "salaris" ? "#6C9EFF" : k === "freelance" ? "#a78bfa" : "#5ECFA0"}"></div>
      <div class="breakdown-label">${k.charAt(0).toUpperCase() + k.slice(1)}</div>
      <div class="breakdown-amount">${eur(v)}</div>
      <div class="breakdown-pct">${Math.round((v / p.maandelijks_inkomen) * 100)}%</div>
    </div>
  `,
          )
          .join("");

        const maxKost = Math.max(...Object.values(p.maandelijkse_kosten));
        const kostBreak = Object.entries(p.maandelijkse_kosten)
          .map(
            ([k, v]) => `
    <div class="bar-item">
      <div class="bar-header"><span class="bar-label">${kostLabels[k]}</span><span class="bar-val">${eur(v)}</span></div>
      <div class="bar-track"><div class="bar-fill" style="width:${Math.round((v / maxKost) * 100)}%;background:${kostKleuren[k]}"></div></div>
    </div>
  `,
          )
          .join("");

        return `
    <div style="max-width:1100px;margin:0 auto;padding:1.5rem 2.5rem 4rem;position:relative;z-index:1">
      <button class="profile-back" onclick="showPage('home')">← Terug naar overzicht</button>

      <div class="profile-header">
        <div class="profile-big-avatar" style="background:${p.avatar_kleur}">${initials(p.naam)}</div>
        <div class="profile-meta">
          <div class="profile-name">${p.naam}</div>
          <div class="profile-sub">
            <span>${p.beroep}</span>
            <span class="profile-sub-dot"></span>
            <span>${p.stad}</span>
            <span class="profile-sub-dot"></span>
            <span>${p.leeftijd} jaar</span>
          </div>
          <div class="profile-login">Laatste login: ${p.laatste_login}</div>
        </div>
        <div class="profile-big-income">
          <div class="profile-income-num">${eur(p.maandelijks_inkomen)}</div>
          <div class="profile-income-lbl">MAANDINKOMEN</div>
        </div>
      </div>

      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-val">${eur(p.maandelijks_inkomen)}</div>
          <div class="stat-lbl">BRUTO INKOMEN</div>
          <div class="stat-change">↑ maandelijks</div>
        </div>
        <div class="stat-card">
          <div class="stat-val">${eur(tk)}</div>
          <div class="stat-lbl">TOTALE KOSTEN</div>
        </div>
        <div class="stat-card">
          <div class="stat-val" style="color:#4ade80">${eur(bal)}</div>
          <div class="stat-lbl">MAANDBALANS</div>
          <div class="stat-change">↑ ${Math.round((bal / p.maandelijks_inkomen) * 100)}% spaarquote</div>
        </div>
        <div class="stat-card">
          <div class="stat-val">${eur(p.spaargeld)}</div>
          <div class="stat-lbl">SPAARGELD</div>
        </div>
      </div>

      <div class="balance-highlight">
        <div class="balance-left">
          <h3>Maandelijkse netto overschot</h3>
          <p>${eur(p.maandelijks_inkomen)} inkomen − ${eur(tk)} kosten</p>
        </div>
        <div class="balance-num">${eur(bal)}</div>
      </div>

      <div class="two-col">
        <div class="breakdown-card">
          <div class="flex-between">
            <div>
              <div class="chart-title">Inkomen bronnen</div>
              <div class="chart-sub">Maandelijks totaal</div>
            </div>
            <div class="pill">+ ${eur(p.maandelijks_inkomen)}</div>
          </div>
          ${incBreak}
        </div>
        <div class="breakdown-card">
          <div class="chart-title">Uitgavenposten</div>
          <div class="chart-sub" style="margin-bottom:1.5rem">Per categorie per maand</div>
          <div class="bar-list">${kostBreak}</div>
        </div>
      </div>

      <div class="two-col">
        <div class="breakdown-card">
          <div class="chart-title" style="margin-bottom:.25rem">Inkomen vs Uitgaven</div>
          <div class="chart-sub">Visuele vergelijking</div>
          <div style="position:relative;height:200px">
            <canvas id="profileChart${p.id}" role="img" aria-label="Bar chart inkomen vs uitgaven voor ${p.naam}"></canvas>
          </div>
        </div>
        <div class="savings-card">
          <div class="chart-title">Spaargeld</div>
          <div class="savings-big">${eur(p.spaargeld)}</div>
          <div class="savings-months">${savMonths} maanden aan levenskosten in reserve</div>
          <div style="margin-top:1.5rem">
            <div class="bar-header" style="margin-bottom:6px"><span class="bar-label">Spaardoel voortgang (richtlijn 6 mnd)</span><span class="bar-val">${Math.min(100, Math.round((p.spaargeld / (tk * 6)) * 100))}%</span></div>
            <div class="bar-track" style="height:8px"><div class="bar-fill" style="width:${Math.min(100, Math.round((p.spaargeld / (tk * 6)) * 100))}%;background:${p.avatar_kleur}"></div></div>
          </div>
        </div>
      </div>
    </div>
  `;
      }

      const profileCharts = {};
      function buildProfileChart(p) {
        if (profileCharts[p.id]) return;
        const ctx = document.getElementById("profileChart" + p.id);
        if (!ctx) return;
        const tk = totalKosten(p);
        profileCharts[p.id] = new Chart(ctx, {
          type: "bar",
          data: {
            labels: ["Inkomen", "Kosten", "Balans"],
            datasets: [
              {
                data: [p.maandelijks_inkomen, tk, p.maandelijks_inkomen - tk],
                backgroundColor: [
                  "rgba(108,158,255,0.7)",
                  "rgba(255,143,171,0.7)",
                  "rgba(74,222,128,0.7)",
                ],
                borderRadius: 6,
                borderWidth: 0,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { display: false }, ticks: { color: "#64748b" } },
              y: {
                grid: { color: "rgba(148,163,184,0.05)" },
                ticks: {
                  color: "#64748b",
                  callback: (v) => "€" + v.toLocaleString("nl-NL"),
                },
              },
            },
          },
        });
      }

      /* ROUTING */
      function showPage(type, id) {
        document
          .querySelectorAll(".page")
          .forEach((p) => p.classList.remove("active"));
        document
          .querySelectorAll(".nav-link")
          .forEach((b) => b.classList.remove("active"));

        if (type === "home") {
          document.getElementById("page-home").classList.add("active");
          document.getElementById("nav-home").classList.add("active");
        } else {
          const page = document.getElementById("page-profile-" + id);
          if (!page.innerHTML) {
            const p = data.find((x) => x.id === id);
            page.innerHTML = buildProfile(p);
          }
          page.classList.add("active");
          document.getElementById("nav-p" + id).classList.add("active");
          setTimeout(
            () => buildProfileChart(data.find((x) => x.id === id)),
            50,
          );
        }
        window.scrollTo(0, 0);
      }

      /* INIT */
      buildPeopleGrid();
      buildLeaderboard();
      setTimeout(buildHomeCharts, 100);
    </script>
  </body>
</html>